# 运行环境: dev (开发环境)、prod (生产环境)
APP_ENV=dev
# 应用进程标识名
APP_NAME=hyadmin
# 超管及角色编号
APP_SUPER_USER=1
# 系统工作的进程数
APP_WORKER_NUMS=
# 系统支持监听端口号
APP_WORKER_PORT=9501

# 前端配置（可选，由 _app.config.js 动态注入前端运行时）
# APP_TITLE=SmartAdmin
# APP_API_URL=/

# 应用日志输出配置
APP_DEBUG_XSQL=true
APP_DEBUG_XLOG=true
# 缓存：默认 file（无 Redis 也可运行）；生产 / 多实例推荐 redis（与下方 REDIS_* 一致）。勿使用 sqlite，旧值将按 file 处理
CACHE_DRIVER=file
CACHE_PREFIX=hyadmin
# CACHE_REDIS_POOL=default

# 数据库配置
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hyadmin
DB_USERNAME=root
DB_PASSWORD=
DB_PREFIX=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Redis缓存配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_AUTH=
REDIS_DB=0