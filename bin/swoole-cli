#!/bin/sh

set -eu

BASE_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
SCRIPT_PATH="$BASE_DIR/bin/swoole-cli"
RUNNER=""
TRIED=""

record_tried() {
  if [ -z "$TRIED" ]; then
    TRIED="$1"
  else
    TRIED="$TRIED, $1"
  fi
}

resolve_runner() {
  case "$1" in
    */*)
      [ -f "$1" ] || return 1
      printf '%s\n' "$1"
      ;;
    *)
      command -v "$1" 2>/dev/null || return 1
      ;;
  esac
}

absolute_path() {
  case "$1" in
    /*)
      printf '%s\n' "$1"
      ;;
    */*)
      PATH_DIR=$(CDPATH= cd -- "$(dirname -- "$1")" 2>/dev/null && pwd) || return 1
      printf '%s/%s\n' "$PATH_DIR" "$(basename -- "$1")"
      ;;
    *)
      printf '%s\n' "$1"
      ;;
  esac
}

is_swoole_runtime() {
  "$1" -r 'exit((PHP_SAPI === "cli" || PHP_SAPI === "phpdbg") && (extension_loaded("swoole") || extension_loaded("openswoole")) ? 0 : 1);' >/dev/null 2>&1
}

try_runner() {
  CANDIDATE="$1"
  [ -n "$CANDIDATE" ] || return 1
  record_tried "$CANDIDATE"

  RESOLVED=$(resolve_runner "$CANDIDATE") || return 1
  RESOLVED=$(absolute_path "$RESOLVED") || return 1
  [ "$RESOLVED" != "$SCRIPT_PATH" ] || return 1

  if [ -f "$RESOLVED" ] && [ ! -x "$RESOLVED" ]; then
    chmod +x "$RESOLVED" 2>/dev/null || true
  fi

  [ -x "$RESOLVED" ] || return 1
  is_swoole_runtime "$RESOLVED" || return 1

  RUNNER="$RESOLVED"
  return 0
}

normalize_arch() {
  case "$1" in
    arm64|aarch64)
      printf '%s\n' "a64"
      ;;
    x86_64|amd64)
      printf '%s\n' "x64"
      ;;
    *)
      printf '%s\n' "$1"
      ;;
  esac
}

OS_NAME=$(uname -s 2>/dev/null || printf '%s\n' "unknown")
ARCH_NAME=$(normalize_arch "$(uname -m 2>/dev/null || printf '%s\n' "unknown")")

# 支持显式指定真实 Swoole CLI，可用于 CI、自定义安装路径或未来新增平台。
if [ -n "${SWOOLE_CLI_BIN:-}" ]; then
  try_runner "$SWOOLE_CLI_BIN" || true
fi

if [ -z "$RUNNER" ] && [ -n "${SWOOLE_CLI:-}" ]; then
  try_runner "$SWOOLE_CLI" || true
fi

# macOS / Linux / WSL 都先选择当前架构对应的项目内置运行时；WSL 识别为 Linux，直接复用 Linux 二进制。
if [ -z "$RUNNER" ]; then
  case "$OS_NAME:$ARCH_NAME" in
    Darwin:a64)
      try_runner "$BASE_DIR/bin/swoole-macos-a64" || true
      ;;
    Darwin:x64)
      try_runner "$BASE_DIR/bin/swoole-macos-x64" || true
      ;;
    Linux:a64)
      try_runner "$BASE_DIR/bin/swoole-linux-a64" || true
      ;;
    Linux:x64)
      try_runner "$BASE_DIR/bin/swoole-linux-x64" || true
      ;;
  esac
fi

# 内置运行时不存在或不可执行时，再尝试系统级真实 Swoole CLI，最后才尝试带 Swoole 扩展的 php。
if [ -z "$RUNNER" ]; then
  try_runner "swoole-cli" || true
fi

if [ -z "$RUNNER" ]; then
  try_runner "swoole" || true
fi

if [ -z "$RUNNER" ]; then
  try_runner "php" || true
fi

if [ -z "$RUNNER" ]; then
  {
    echo "No compatible Swoole CLI runtime found."
    echo "Detected platform: $OS_NAME/$ARCH_NAME"
    echo "Tried: ${TRIED:-none}"
    echo "Set SWOOLE_CLI_BIN=/path/to/php-with-swoole or add a matching bin/swoole-* runtime."
  } >&2
  exit 127
fi

if [ -n "${SWOOLE_CLI_DEBUG:-}" ]; then
  echo "Using Swoole CLI runtime: $RUNNER" >&2
fi

exec "$RUNNER" "$@"
