            {
              "id": 3142,
              "name": "退款记录",
              "code": "wechat.client.payment.refund.index",
              "route": "/wechat/client/payment/refund",
              "icon": "lucide:rotate-ccw",
              "sort": 30,
              "view": "payment/refund/index.vue",
              "module": {
                "key": "wechat-client-payment-refund",
