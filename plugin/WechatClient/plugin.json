          "redirect": "/wechat/client/payment/merchant",
          "menus": [
            {
              "id": 3140,
              "name": "支付商户",
              "code": "wechat.client.payment.merchant.index",
              "route": "/wechat/client/payment/merchant",
              "icon": "lucide:badge-japanese-yen",
              "sort": 50,
              "view": "payment/merchant/index.vue",
              "module": {
                "key": "wechat-client-payment-merchant",
                "summary": "微信支付 APIv3 商户配置、证书和回调参数管理。",
                "features": [
