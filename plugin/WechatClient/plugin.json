                  "id": 31301,
                  "name": "保存菜单",
                  "code": "wechat.client.menu.save",
                  "sort": 10
                },
                {
                  "id": 31302,
                  "name": "发布菜单",
                  "code": "wechat.client.menu.publish",
                  "sort": 20
                },
                {
                  "id": 31303,
                  "name": "删除菜单",
                  "code": "wechat.client.menu.delete",
                  "sort": 30
                }
              ]
