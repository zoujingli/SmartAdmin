              "id": 3141,
              "name": "支付订单",
              "code": "wechat.client.payment.order.index",
              "route": "/wechat/client/payment/order",
              "icon": "lucide:receipt-text",
              "sort": 40,
              "view": "payment/order/index.vue",
              "module": {
                "key": "wechat-client-payment-order",
                "summary": "微信支付订单流水、主动查单补偿和退款入口管理。",
                "features": [
