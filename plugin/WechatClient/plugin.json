{
  "plugin": {
    "code": "wechat-client",
    "name": "微信公众号平台",
    "version": "1.0.0",
    "description": "Apache-2.0 开源插件，提供租户侧公众号、小程序、粉丝、菜单、回复、素材和微信支付管理。",
    "license_name": "Apache License 2.0",
    "license_type": "open_source",
    "license_url": "https://www.apache.org/licenses/LICENSE-2.0",
    "pricing_type": "free",
    "support_url": "https://github.com/zoujingli/SmartAdmin/issues",
    "license_notice": "本插件随 SmartAdmin 以 Apache License 2.0 开源发布；使用微信相关能力仍需遵守微信官方平台、支付和数据安全协议。",
    "view_root": "stc/view",
    "language_root": "stc/languages",
    "migration_root": "stc/migrations"
  },
  "apps": [
    {
      "id": 3100,
      "name": "微信公众号平台",
      "route": "/wechat/client",
      "component": "BasicLayout",
      "icon": "lucide:message-circle",
      "sort": 70,
      "type": "D",
      "redirect": "/wechat/client/account",
      "menus": [
        {
          "id": 3101,
          "name": "基础管理",
          "route": "/wechat/client/basic",
          "icon": "lucide:settings-2",
          "sort": 50,
          "type": "D",
          "redirect": "/wechat/client/account",
          "menus": [
            {
              "id": 3110,
              "name": "接口账号",
              "code": "wechat.client.account.index",
              "route": "/wechat/client/account",
              "icon": "lucide:settings-2",
              "sort": 50,
              "view": "account/index.vue",
              "module": {
                "key": "wechat-client-account",
                "summary": "租户侧公众号与小程序账号绑定、接口配置和回调入口。",
                "features": [
                  "账号绑定",
                  "安全脱敏",
                  "回调配置",
                  "SDK 调用"
                ]
              },
              "permissions": [
                {
                  "id": 31101,
                  "name": "新增接口账号",
                  "code": "wechat.client.account.create",
                  "sort": 10
                },
                {
                  "id": 31102,
                  "name": "编辑接口账号",
                  "code": "wechat.client.account.update",
                  "sort": 20
                },
                {
                  "id": 31103,
                  "name": "删除接口账号",
                  "code": "wechat.client.account.delete",
                  "sort": 30
                }
              ]
            },
            {
              "id": 3120,
              "name": "粉丝管理",
              "code": "wechat.client.user.index",
              "route": "/wechat/client/user",
              "icon": "lucide:users",
              "sort": 40,
              "view": "user/index.vue",
              "module": {
                "key": "wechat-client-user",
                "summary": "公众号粉丝、本地标签和同步状态管理。",
                "features": [
                  "粉丝列表",
                  "标签管理",
                  "同步记录"
                ]
              },
              "permissions": [
                {
                  "id": 31201,
                  "name": "同步粉丝",
                  "code": "wechat.client.user.sync",
                  "sort": 10
                }
              ]
            }
          ]
