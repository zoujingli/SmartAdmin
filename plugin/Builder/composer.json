{
  "name": "zoujingli/smart-admin-builder",
  "description": "SmartAdmin builder component for packaging Hyperf projects as Phar/SFX stand-alone packages.",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "license": "Apache-2.0",
  "version": "1.0.0",
  "homepage": "https://hyperf.io",
  "require": {
    "php": ">=8.4",
    "ext-json": "*",
    "hyperf/command": "^3.2",
    "hyperf/contract": "^3.2",
    "nikic/php-parser": "^5.6",
    "psr/container": "^1.0 || ^2.0",
    "symfony/finder": "^7.3 || ^8.0"
  },
  "autoload": {
    "psr-4": {
      "Builder\\": "./"
    }
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "branch-alias": {
      "dev-master": "3.1-dev"
    },
    "hyperf": {
      "config": "Builder\\Provider"
    }
  }
}
