{
  "name": "zoujingli/smart-plugin-website",
  "description": "Generic website CMS data module plugin for SmartAdmin.",
  "type": "library",
  "license": "Apache-2.0",
  "version": "1.0.0",
  "authors": [
    {
      "name": "Anyon",
      "email": "zoujingli@qq.com"
    }
  ],
  "require": {
    "php": ">=8.4",
    "ext-dom": "*",
    "ext-json": "*",
    "zoujingli/smart-admin-library": "^1.0",
    "zoujingli/smart-plugin-system": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Plugin\\Website\\": "src/"
    }
  },
  "extra": {
    "hyperf": {
      "config": "Plugin\\Website\\Provider"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "keywords": [
    "smartadmin",
    "website",
    "cms"
  ]
}
